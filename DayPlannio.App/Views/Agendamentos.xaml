<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:DayPlannio.App.Views"
             x:Class="DayPlannio.App.Views.Agendamentos"
             NavigationPage.HasNavigationBar="False"
             Title="Agendamentos"
             BackgroundColor="#F5F5F5">

	<Grid RowDefinitions="*,Auto">

		<ScrollView Grid.Row="0">
			<VerticalStackLayout Padding="20">

				<Label Text="Agendamentos" FontSize="22" FontAttributes="Bold" TextColor="#181C1C" />

				<Label Text="Gerencie seus agendamentos aqui." FontSize="13" TextColor="#3E4948" Margin="0,5,0,20" />

				<Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 15" Padding="20">
					<VerticalStackLayout Spacing="10">
						<Label Text="Nenhum agendamento encontrado" TextColor="Gray" HorizontalOptions="Center" />
					</VerticalStackLayout>
				</Border>

			</VerticalStackLayout>
		</ScrollView>

		<views:CustomTabBar Grid.Row="1" />

	</Grid>

</ContentPage>