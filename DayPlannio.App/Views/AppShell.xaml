<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DayPlannio.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:DayPlannio.App.Views"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="True">

    <TabBar>
    <ShellContent Title="Agenda" 
                  ContentTemplate="{DataTemplate views:Agendamentos}"
                  Route="Agendamentos"/>

    <ShellContent Title="Serv."
                  ContentTemplate="{DataTemplate views:Servicos}"
                  Route="Servicos"/>

    <ShellContent Title="Clientes"
                  ContentTemplate="{DataTemplate views:Clientes}"
                  Route="Clientes"/>

    <ShellContent Title="Fin."
                  ContentTemplate="{DataTemplate views:Financeiro}"
                  Route="Financeiro"/>

    <ShellContent Title="Perfil"
                  ContentTemplate="{DataTemplate views:MeuPerfil}"
                  Route="MeuPerfil"/>
</TabBar>

</Shell>