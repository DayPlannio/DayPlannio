<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:DayPlannio.App.Views"
    x:Class="DayPlannio.App.Views.CadastrarFinanceiro"
    BackgroundColor="#F5F5F5"
    NavigationPage.HasNavigationBar="False"
    Title="Nova Entrada">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">

            <VerticalStackLayout>

                <Grid
                    Padding="20,20,20,0"
                    VerticalOptions="Center">

                    <Label
                        Text="Entradas e Saidas"
                        FontSize="17"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        TextColor="{StaticResource PrimaryColor}" />

                    <ImageButton
                        Source="icon_seta_esquerda.png"
                        WidthRequest="10"
                        HeightRequest="10"
                        Padding="2"
                        BackgroundColor="Transparent"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        Clicked="OnBackClicked" />

                </Grid>

                <VerticalStackLayout Padding="20,20,20,0">

                    <Label
                        Text="Adicione Entradas e Saídas"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="#181C1C" />

                    <Label
                        Text="Preencha as entradas e saidas do seu negócio"
                        FontSize="13"
                        TextColor="#3E4948" />

                </VerticalStackLayout>

                <VerticalStackLayout
                    Padding="20"
                    Spacing="15">

                    <VerticalStackLayout Spacing="8">

                        <Label
                            Text="TIPO"
                            FontSize="11"
                            TextColor="#3E4948" />

                        <Border
                            BackgroundColor="#EBEBEB"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            Padding="12,0">

                            <Grid ColumnDefinitions="*,Auto">

                                <Label
                                    x:Name="lblTipo"
                                    Text="Entrada/Saida"
                                    FontSize="14"
                                    TextColor="#555"
                                    VerticalOptions="Center" />

                                <Image
                                    Grid.Column="1"
                                    Source="icon_seta_baixo.png"
                                    WidthRequest="12"
                                    HeightRequest="12"
                                    VerticalOptions="Center" />

                                <Picker
                                    x:Name="picker_"
                                    Opacity="0.01"
                                    HeightRequest="45"
                                    Title="Selecione um cliente"
                                    SelectedIndexChanged="OnTipoChanged" />

                            </Grid>

                        </Border>

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="10">

                        <Label
                            Text="DESCRIÇÃO"
                            FontSize="11"
                            TextColor="#3E4948" />

                        <Border
                            BackgroundColor="#EBEBEB"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10">

                            <Editor
                                x:Name="txt_observacoes"
                                Placeholder="Descreva sobre a entrada ou saida..."
                                HeightRequest="100"
                                BackgroundColor="Transparent" />

                        </Border>

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">

                        <Label
                            Text="DATA DO ATENDIMENTO"
                            FontSize="11"
                            TextColor="#3E4948" />

                        <Border
                            BackgroundColor="#EBEBEB"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            Padding="12,0">

                            <Grid ColumnDefinitions="*,Auto">

                                <Label
                                    x:Name="lblData"
                                    Text="Selecionar data"
                                    FontSize="14"
                                    TextColor="#555"
                                    VerticalOptions="Center" />

                                <Image
                                    Grid.Column="1"
                                    Source="icon_seta_baixo.png"
                                    WidthRequest="12"
                                    HeightRequest="12"
                                    VerticalOptions="Center" />

                                <DatePicker
                                    x:Name="date_atendimento"
                                    Opacity="0.01"
                                    HeightRequest="45"
                                    DateSelected="OnDataChanged" />

                            </Grid>

                        </Border>

                        <Label
                            Text="HORÁRIO"
                            FontSize="11"
                            TextColor="#3E4948"
                            Margin="0,10,0,0" />

                        <Border
                            BackgroundColor="#EBEBEB"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            Padding="12,0">

                            <Grid ColumnDefinitions="*,Auto">

                                <Label
                                    x:Name="lblHorario"
                                    Text="Selecionar horário"
                                    FontSize="14"
                                    TextColor="#555"
                                    VerticalOptions="Center" />

                                <Image
                                    Grid.Column="1"
                                    Source="icon_seta_baixo.png"
                                    WidthRequest="12"
                                    HeightRequest="12"
                                    VerticalOptions="Center" />

                                <TimePicker
                                    x:Name="time_horario"
                                    Opacity="0.01"
                                    HeightRequest="45"
                                    Format="HH:mm"
                                    PropertyChanged="OnHorarioChanged" />

                            </Grid>

                        </Border>

                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="10">

                        <Label
                            Text="VALOR"
                            FontSize="11"
                            TextColor="#3E4948"
                            Margin="0,8,0,0" />

                        <Border
                            BackgroundColor="#EBEBEB"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            Padding="12,0">

                            <Grid
                                ColumnDefinitions="Auto,*"
                                ColumnSpacing="8">

                                <Label
                                    Text="R$"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    TextColor="#3E4948"
                                    VerticalOptions="Center" />

                                <Entry
                                    Grid.Column="1"
                                    x:Name="txt_valor"
                                    Placeholder="0,00"
                                    Keyboard="Numeric"
                                    HeightRequest="45"
                                    BackgroundColor="Transparent" />

                            </Grid>

                        </Border>

                    </VerticalStackLayout>

                    <Button
                        Text="Adicionar"
                        TextColor="White"
                        CornerRadius="25"
                        HeightRequest="50"
                        Clicked="OnConfirmarClicked">

                        <Button.Background>

                            <LinearGradientBrush
                                StartPoint="0,0"
                                EndPoint="1,0">

                                <GradientStop
                                    Color="#006260"
                                    Offset="0.0" />

                                <GradientStop
                                    Color="#1E7C7A"
                                    Offset="1.0" />

                            </LinearGradientBrush>

                        </Button.Background>

                    </Button>

                    <Button
                        Text="Cancelar"
                        BackgroundColor="Transparent"
                        TextColor="Gray"
                        Clicked="OnCancelarClicked" />

                </VerticalStackLayout>

            </VerticalStackLayout>

        </ScrollView>

        <views:CustomTabBar Grid.Row="1" />

    </Grid>

</ContentPage>